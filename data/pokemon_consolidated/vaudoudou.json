      "names": {
        "en": "Voodoll",
        "fr": "Vaudoudou",
        "it": "Houndour",
        "de": "Hunduster",
        "es": "Houndour",
        "ko": "델빌"
      },
      "descriptions": {
        "en": "Voodoll is extremely attached to its needle, using it as a shield to protect its fragile fabric body.",
        "fr": "Vaudoudou est extrêment attaché à son épingle, celle-ci lui servant de bouclier pour protéger son corps fragile en tissu.",
        "it": "Agisce sempre in squadra con i suoi simili. È un compagno fedele e segue attentamente le istruzioni del suo Allenatore.",
        "de": "Es ist auf Zusammenarbeit spezialisiert und folgt den Befehlen seines Trainers aufs Wort.",
        "es": "Famoso por su lealtad y ánimo cooperativo. Obedecerá sin dudar todo cuanto le ordene su Entrenador.",
        "ko": "동료와의 연계가 특기다. 파트너가되면 트레이너의 명령에 매우 충실하다."
      },
      "abilities_data": [
        {
          "symbol": "cursed_body",
          "textId": 130,
          "names": {
            "en": "Cursed Body",
            "fr": "Corps Maudit",
            "it": "Corpofunesto",
            "de": "Tastfluch",
            "es": "Cuerpo Maldito",
            "ko": "저주받은바디"
          },
          "descriptions": {
            "en": "May disable a move used on the Pokémon.",
            "fr": "Quand le Pokémon est touché par une capacité, il inflige parfois Entrave sur celle-ci.",
            "it": "Può bloccare la mossa subita dal Pokémon.",
            "de": "Blockiert eventuell die Attacke, mit welcher der Angreifer es getroffen hat.",
            "es": "Puede anular el movimiento usado en su contra.",
            "ko": "공격을 받으면 상대의 기술을 사슬묶기 상태로 만들 때가 있다."
          }
        },
        {
          "symbol": "aftermath",
          "textId": 106,
          "names": {
            "en": "Aftermath",
            "fr": "Boom Final",
            "it": "Scoppio",
            "de": "Finalschlag",
            "es": "Detonación",
            "ko": "유폭"
          },
          "descriptions": {
            "en": "Damages the attacker if it contacts the Pokémon with a finishing hit.",
            "fr": "Si le Pokémon est mis K.O. par une attaque directe, il inflige des dégâts à l’attaquant avant de s’évanouir.",
            "it": "Chi manda KO questo Pokémon con un attacco diretto subisce dei danni.",
            "de": "Wird das Pokémon durch eine direkte Attacke besiegt, fügt es dem Angreifer Schaden zu.",
            "es": "Daña al agresor que le ha dado el golpe de gracia con un movimiento de contacto.",
            "ko": "기절했을 때 접촉한 상대에게 데미지를 준다."
          }
        },
        {
          "symbol": "anger_point",
          "textId": 83,
          "names": {
            "en": "Anger Point",
            "fr": "Colérique",
            "it": "Grancollera",
            "de": "Kurzschluss",
            "es": "Irascible",
            "ko": "분노의경혈"
          },
          "descriptions": {
            "en": "The Pokémon is angered when it takes a critical hit, and that maxes its Attack stat.",
            "fr": "Si le Pokémon subit un coup critique, il entre dans une colère noire qui augmente son Attaque au maximum.",
            "it": "Se il Pokémon subisce un brutto colpo, monta su tutte le furie e il suo Attacco aumenta al massimo.",
            "de": "Wird nach Einstecken eines Volltreffers wütend und maximiert dabei seinen Angriffs-Wert.",
            "es": "Si recibe un golpe crítico, monta en cólera y sube su Ataque hasta el máximo.",
            "ko": "급소에 공격이 맞으면 크게 분노해 공격력이 최대가 된다."
          }
        }
      ],
