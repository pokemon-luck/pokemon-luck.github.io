      "names": {
        "en": "Zeustrix",
        "fr": "Zeustrix",
        "it": "Donphan",
        "de": "Donphan",
        "es": "Donphan",
        "ko": "코리갑"
      },
      "descriptions": {
        "en": " ",
        "fr": "",
        "it": "Il massiccio corpo di Donphan dispone di una forza tale da poter abbattere persino una casa. La sua incredibile potenza aiuta a liberare i sentieri montani dopo una frana di massi o fango.",
        "de": "Donphan kann mit seinem harten Körper sogar ein Haus zerstören. Mit seiner imposanten Kraft hilft dieses Pokémon dabei, Erdrutsche aus dem Weg zu räumen, die Bergpfade versperren.",
        "es": "Si Donphan tuviera que dar un golpe con todo el cuerpo, con lo robusto que es echaría abajo hasta una casa. Estos Pokémon usan su fuerza para ayudar a despejar pasos de montaña cuando hay piedras o lodo.",
        "ko": "단단한 몸으로 부딪치면 집도 부서진다. 그 힘을 이용해 산길을 막고 있는 토사를 치우는 일을 돕는다."
      },
      "abilities_data": [
        {
          "symbol": "gale_wings",
          "textId": 177,
          "names": {
            "en": "Gale Wings",
            "fr": "Ailes Bourrasque",
            "it": "Aliraffica",
            "de": "Orkanschwingen",
            "es": "Alas Vendaval",
            "ko": "질풍날개"
          },
          "descriptions": {
            "en": "Gives priority to Flying-type moves when the Pokémon’s HP is full.",
            "fr": "Quand les PV du Pokémon sont au maximum, ses capacités de type Vol sont prioritaires.",
            "it": "Se il Pokémon ha tutti i PS, le sue mosse di tipo Volante acquistano priorità alta.",
            "de": "Kann bei vollen KP einen Erstschlag mit Flug-Attacken ermöglichen.",
            "es": "Da prioridad a los movimientos de tipo Volador si sus PS están al máximo.",
            "ko": "HP가 꽉 찼을 때 비행타입의 기술을 먼저 쓸 수 있다."
          }
        },
        {
          "symbol": "serene_grace",
          "textId": 32,
          "names": {
            "en": "Serene Grace",
            "fr": "Sérénité",
            "it": "Leggiadro",
            "de": "Edelmut",
            "es": "Dicha",
            "ko": "하늘의은총"
          },
          "descriptions": {
            "en": "Boosts the likelihood of additional effects occurring when attacking.",
            "fr": "Augmente les chances d’infliger des effets additionnels.",
            "it": "Rende più probabili gli effetti aggiuntivi delle mosse.",
            "de": "Erhöht die Wahrscheinlichkeit, dass Zusatzeffekte von Attacken auftreten.",
            "es": "Aumenta la probabilidad de que los movimientos causen efectos secundarios.",
            "ko": "하늘의 은총 덕분에 기술의 추가 효과가 나오기 쉽다."
          }
        },
        {
          "symbol": "speed_boost",
          "textId": 3,
          "names": {
            "en": "Speed Boost",
            "fr": "Turbo",
            "it": "Acceleratore",
            "de": "Temposchub",
            "es": "Impulso",
            "ko": "가속"
          },
          "descriptions": {
            "en": "Its Speed stat is boosted every turn.",
            "fr": "La Vitesse du Pokémon augmente à chaque tour.",
            "it": "La Velocità aumenta a ogni turno.",
            "de": "Erhöht in jeder Runde die Initiative.",
            "es": "Aumenta su Velocidad en cada turno.",
            "ko": "매 턴 스피드가 올라간다."
          }
        }
