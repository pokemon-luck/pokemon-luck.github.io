      "names": {
        "en": "Archael",
        "fr": "Archael",
        "it": "Kingler",
        "de": "Kingler",
        "es": "Kingler",
        "ko": "킹크랩"
      },
      "descriptions": {
        "en": "Archael relentlessly protects the Dawn Stone that caused its evolution. No one has been able to explain this behavior to this day.",
        "fr": "Archael protège sans relâche la pierre Aube qui l'a fait évoluer. Personne n'a été capable d'expliquer ce comportement à ce jour.",
        "it": "Kingler è dotato di un’enorme chela, che brandisce nell’aria per comunicare con i suoi simili. Tuttavia, dato il notevole peso della chela sovradimensionata, il Pokémon si stanca in fretta.",
        "de": "Kingler hat eine riesige Schere. Es winkt damit, um mit anderen zu kommunizieren. Da seine Schere aber so schwer ist, wird dieses Pokémon schnell müde.",
        "es": "Kingler tiene una pinza enorme y descomunal que usa agitándola en el aire para comunicarse con otros. Lo malo es que, al pesarle tanto, se cansa enseguida.",
        "ko": "킹크랩은 거대한 집게를 휘둘러 동료 간에 신호를 보내지만 집게가 무거워서 곧 지쳐버린다."
      },
      "abilities_data": [
        {
          "symbol": "serene_grace",
          "textId": 32,
          "names": {
            "en": "Serene Grace",
            "fr": "Sérénité",
            "it": "Leggiadro",
            "de": "Edelmut",
            "es": "Dicha",
            "ko": "하늘의은총"
          },
          "descriptions": {
            "en": "Boosts the likelihood of additional effects occurring when attacking.",
            "fr": "Augmente les chances d’infliger des effets additionnels.",
            "it": "Rende più probabili gli effetti aggiuntivi delle mosse.",
            "de": "Erhöht die Wahrscheinlichkeit, dass Zusatzeffekte von Attacken auftreten.",
            "es": "Aumenta la probabilidad de que los movimientos causen efectos secundarios.",
            "ko": "하늘의 은총 덕분에 기술의 추가 효과가 나오기 쉽다."
          }
        },
        {
          "symbol": "healer",
          "textId": 131,
          "names": {
            "en": "Healer",
            "fr": "Cœur Soin",
            "it": "Curacuore",
            "de": "Heilherz",
            "es": "Alma Cura",
            "ko": "치유의마음"
          },
          "descriptions": {
            "en": "Sometimes heals an ally’s status condition.",
            "fr": "Soigne parfois une altération de statut d’un allié proche.",
            "it": "A volte cura i problemi di stato degli alleati.",
            "de": "Befreit Mitstreiter gelegentlich von Statusproblemen.",
            "es": "A veces cura los problemas de estado de un aliado.",
            "ko": "같은 편의 상태 이상을 가끔 회복시킨다."
          }
        },
        {
          "symbol": "wonder_skin",
          "textId": 147,
          "names": {
            "en": "Wonder Skin",
            "fr": "Peau Miracle",
            "it": "Splendicute",
            "de": "Wunderhaut",
            "es": "Piel Milagro",
            "ko": "미라클스킨"
          },
          "descriptions": {
            "en": "Makes status moves more likely to miss.",
            "fr": "Le Pokémon résiste mieux aux capacités de statut.",
            "it": "Il Pokémon resiste più facilmente alle mosse di stato.",
            "de": "Wehrt mit robustem Körper viele Status-Attacken ab.",
            "es": "Presenta una mayor resistencia ante los movimientos de estado.",
            "ko": "변화 기술을 받기 어려운 몸으로 되어 있다."
          }
        }
