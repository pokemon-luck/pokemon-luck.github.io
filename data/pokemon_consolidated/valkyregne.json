      "names": {
        "en": "Valkyreign",
        "fr": "Valkyrègne",
        "it": "Smeargle",
        "de": "Farbeagle",
        "es": "Smeargle",
        "ko": "루브도"
      },
      "descriptions": {
        "en": " ",
        "fr": "",
        "it": "Dalla punta della coda secerne un fluido corporeo la cui tonalità cambia in base alle sue emozioni.",
        "de": "Der Farbton der Flüssigkeit, die aus seiner Schweifspitze austritt, ändert sich je nach Gefühlslage.",
        "es": "La tonalidad del líquido que libera por la cola cambia en función de su estado anímico.",
        "ko": "꼬리 끝에서 나오는 체액은 루브도의 감정에 따라 색조가 변화한다."
      },
      "abilities_data": [
        {
          "symbol": "justified",
          "textId": 154,
          "names": {
            "en": "Justified",
            "fr": "Cœur Noble",
            "it": "Giustizia",
            "de": "Redlichkeit",
            "es": "Justiciero",
            "ko": "정의의마음"
          },
          "descriptions": {
            "en": "Being hit by a Dark-type move boosts the Attack stat of the Pokémon, for justice.",
            "fr": "Réveille la noblesse du Pokémon lorsqu’il subit une capacité de type Ténèbres, ce qui augmente son Attaque.",
            "it": "Quando il Pokémon viene colpito da una mossa di tipo Buio, il suo forte senso di giustizia fa sì che l’Attacco aumenti.",
            "de": "Wird es von einer Unlicht-Attacke getroffen, meldet sich sein Sinn für Gerechtigkeit zu Wort und sein Angriff steigt.",
            "es": "Si le alcanza un movimiento de tipo Siniestro, aumenta el Ataque debido a su integridad.",
            "ko": "악타입 공격을 받으면 정의감으로 공격이 올라간다."
          }
        },
        {
          "symbol": "intimidate",
          "textId": 22,
          "names": {
            "en": "Intimidate",
            "fr": "Intimidation",
            "it": "Prepotenza",
            "de": "Bedroher",
            "es": "Intimidación",
            "ko": "위협"
          },
          "descriptions": {
            "en": "The Pokémon intimidates opposing Pokémon upon entering battle, lowering their Attack stat.",
            "fr": "Le Pokémon rugit lorsqu’il arrive au combat, ce qui intimide l’ennemi et baisse son Attaque.",
            "it": "Quando il Pokémon entra in campo, la sua prepotenza intimidisce i nemici, riducendone l’Attacco.",
            "de": "Senkt den Angriff der Gegner, indem es sie gleich zu Kampfantritt bedroht und einschüchtert.",
            "es": "Al entrar en combate amilana al rival de tal manera que su Ataque disminuye.",
            "ko": "등장했을 때 위협해서 상대를 위축시켜 상대의 공격을 떨어뜨린다."
          }
        },
        {
          "symbol": "defiant",
          "textId": 128,
          "names": {
            "en": "Defiant",
            "fr": "Acharné",
            "it": "Agonismo",
            "de": "Siegeswille",
            "es": "Competitivo",
            "ko": "오기"
          },
          "descriptions": {
            "en": "Boosts the Pokémon’s Attack stat sharply when its stats are lowered.",
            "fr": "Augmente beaucoup l’Attaque du Pokémon quand ses stats baissent.",
            "it": "L’Attacco aumenta di molto quando le statistiche diminuiscono a causa di un nemico.",
            "de": "Erhöht den Angriff stark, wenn ein Statuswert gesenkt wurde.",
            "es": "Sube mucho su Ataque cuando el rival le baja las características.",
            "ko": "능력이 떨어지면 공격이 크게 올라간다."
          }
        }
      ],
