      "names": {
        "en": "Amabyss",
        "fr": "Amabysse",
        "it": "Mantine",
        "de": "Mantax",
        "es": "Mantine",
        "ko": "만타인"
      },
      "descriptions": {
        "en": "Amabyss builds its nest using seaweed, coral or any sunken item. It usually chooses a spot deep in the water, away from danger.",
        "fr": "Amabysse construit son nid à l'aide d'algues, corail ou tout autre objet ayant coulé. Il choisit souvent un emplacement au fond de l'eau, à l'abri de tout danger.",
        "it": "Volteggia con grazia sulle onde ed è raffigurato in cartoline e poster di Alola molto apprezzati come souvenir.",
        "de": "Postkarten und Poster, auf denen Mantax elegant über die Wellen springt, sind beliebte Mitbringsel aus Alola.",
        "es": "Un souvenir típico de Alola son las postales y pósteres con dibujos de Mantine saltando grácilmente sobre las olas del mar.",
        "ko": "우아하게 파도 위를 튀어 오르는 만타인을 그린 그림엽서나 포스터는 인기 있는 알로라 특산품이다."
      },
      "abilities_data": [
        {
          "symbol": "pickpocket",
          "textId": 124,
          "names": {
            "en": "Pickpocket",
            "fr": "Pickpocket",
            "it": "Arraffalesto",
            "de": "Langfinger",
            "es": "Hurto",
            "ko": "나쁜손버릇"
          },
          "descriptions": {
            "en": "Steals an item from an attacker that made direct contact.",
            "fr": "Vole l’objet que tient l’attaquant quand le Pokémon subit une attaque directe.",
            "it": "Se il Pokémon viene colpito da un attacco diretto, ruba lo strumento di chi lo ha attaccato.",
            "de": "Stiehlt das Item des Angreifers bei Berührung.",
            "es": "Si el rival usa un movimiento de contacto al atacar, le roba el objeto.",
            "ko": "접촉한 상대의 도구를 훔친다."
          }
        },
        {
          "symbol": "rain_dish",
          "textId": 44,
          "names": {
            "en": "Rain Dish",
            "fr": "Cuvette",
            "it": "Copripioggia",
            "de": "Regengenuss",
            "es": "Cura Lluvia",
            "ko": "젖은접시"
          },
          "descriptions": {
            "en": "The Pokémon gradually regains HP in rain.",
            "fr": "Le Pokémon récupère progressivement des PV lorsqu’il pleut.",
            "it": "Il Pokémon recupera PS quando piove.",
            "de": "Regeneriert bei Regen nach und nach KP.",
            "es": "Recupera PS de forma gradual cuando llueve.",
            "ko": "비가 오는 날씨일 때 조금씩 HP를 회복한다."
          }
        },
        {
          "symbol": "defiant",
          "textId": 128,
          "names": {
            "en": "Defiant",
            "fr": "Acharné",
            "it": "Agonismo",
            "de": "Siegeswille",
            "es": "Competitivo",
            "ko": "오기"
          },
          "descriptions": {
            "en": "Boosts the Pokémon’s Attack stat sharply when its stats are lowered.",
            "fr": "Augmente beaucoup l’Attaque du Pokémon quand ses stats baissent.",
            "it": "L’Attacco aumenta di molto quando le statistiche diminuiscono a causa di un nemico.",
            "de": "Erhöht den Angriff stark, wenn ein Statuswert gesenkt wurde.",
            "es": "Sube mucho su Ataque cuando el rival le baja las características.",
            "ko": "능력이 떨어지면 공격이 크게 올라간다."
          }
        }
