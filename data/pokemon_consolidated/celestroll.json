      "names": {
        "en": "Folklear",
        "fr": "Célestroll",
        "it": "Tyrogue",
        "de": "Rabauz",
        "es": "Tyrogue",
        "ko": "배루키"
      },
      "descriptions": {
        "en": " ",
        "fr": "",
        "it": "Tyrogue ha bisogno di allenarsi ogni giorno per scaricare la sua energia. Gli Allenatori che lo allevano devono stabilire e praticare diverse metodologie di allenamento.",
        "de": "Rabauz muss jeden Tag trainieren, sonst ist es nicht ausgelastet und reagiert gestresst. Wenn man dieses Pokémon trainiert, muss man zahlreiche Trainingsmethoden einsetzen und ausbauen.",
        "es": "Tyrogue se pone demasiado nervioso si no lo sacan a entrenarse cada día. Su Entrenador debe establecer y mantener ciertos métodos de entrenamiento durante la cría.",
        "ko": "매일 트레이닝하지 않으면 스트레스가 쌓이기 때문에 트레이너는 키울 때 스케줄 관리에 여러모로 고민해야 한다."
      },
      "abilities_data": [
        {
          "symbol": "illuminap",
          "textId": 307,
          "names": {
            "en": "Illuminap",
            "fr": "Illumina-sieste",
            "it": "Illumina-sieste",
            "de": "Illumina-sieste",
            "es": "Illumina-sieste",
            "ko": "Illumina-sieste"
          },
          "descriptions": {
            "en": "When falling asleep, the Pokémon emits a blinding light, strongly lowering the accuracy of the other Pokémon.",
            "fr": "En s'endormant, le pokémon émet une lueur intense, baissant beaucoup la précision des autres Pokémon.",
            "it": "En s'endormant, le pokémon émet une lueur intense, baissant beaucoup la précision des autres Pokémon.",
            "de": "En s'endormant, le pokémon émet une lueur intense, baissant beaucoup la précision des autres Pokémon.",
            "es": "En s'endormant, le pokémon émet une lueur intense, baissant beaucoup la précision des autres Pokémon.",
            "ko": "En s'endormant, le pokémon émet une lueur intense, baissant beaucoup la précision des autres Pokémon."
          }
        },
        {
          "symbol": "levitate",
          "textId": 26,
          "names": {
            "en": "Levitate",
            "fr": "Lévitation",
            "it": "Levitazione",
            "de": "Schwebe",
            "es": "Levitación",
            "ko": "부유"
          },
          "descriptions": {
            "en": "By floating in the air, the Pokémon receives full immunity to all Ground-type moves.",
            "fr": "Le Pokémon flotte, ce qui l’immunise contre les capacités de type Sol.",
            "it": "La capacità di levitare conferisce al Pokémon immunità agli attacchi di tipo Terra.",
            "de": "Verleiht volle Immunität gegen alle Boden-Attacken durch Schwebezustand.",
            "es": "Su capacidad de flotar sobre el suelo le proporciona inmunidad frente a los movimientos de tipo Tierra.",
            "ko": "땅에서 뜨는 것으로 땅타입의 기술을 받지 않는다."
          }
        },
        {
          "symbol": "unaware",
          "textId": 109,
          "names": {
            "en": "Unaware",
            "fr": "Inconscient",
            "it": "Imprudenza",
            "de": "Unkenntnis",
            "es": "Ignorante",
            "ko": "천진"
          },
          "descriptions": {
            "en": "When attacking, the Pokémon ignores the target Pokémon’s stat changes.",
            "fr": "Quand il attaque, le Pokémon ignore les changements de stats de l’ennemi.",
            "it": "Quando il Pokémon attacca, ignora le modifiche alle statistiche del nemico.",
            "de": "Greift das Pokémon an, ignoriert es sämtliche Statusveränderungen des Zieles.",
            "es": "Pasa por alto las mejoras en las características del rival al atacar.",
            "ko": "상대의 능력 변화를 무시하고 공격할 수 있다."
          }
        }
      ],
