      "names": {
        "en": "Flintetra",
        "fr": "Tétrapace",
        "it": "Delibird",
        "de": "Botogel",
        "es": "Delibird",
        "ko": "딜리버드"
      },
      "descriptions": {
        "en": "Known for its durability, the Tetrapier can survive for several days without water, while its sturdy and sharp feathers repel any predator.",
        "fr": "Connu pour sa durabilité, Tétrapace peut survivre plusieurs jours sans eau, tandis que ses plumes solides et affutées repoussent tout prédateur.",
        "it": "Se incontra qualcuno che si è perso, condivide il cibo che ha con sé. È onnivoro, perciò potrebbe offrire anche dei Pokémon Coleottero.",
        "de": "Es teilt sein Futter mit Menschen in Not. Da es ein Allesfresser ist, kann es passieren, dass sie auch mal Käfer-Pokémon bekommen.",
        "es": "Si ve a alguien en apuros, comparte su alimento con él. Aunque, al ser omnívoro, podría ser que compartiera algún que otro Pokémon insecto.",
        "ko": "조난 당한 사람에게 자신의 먹이를 나눠준다. 잡식이어서 벌레포켓몬을 건네주기도 한다."
      },
      "abilities_data": [
        {
          "symbol": "sturdy",
          "textId": 5,
          "names": {
            "en": "Sturdy",
            "fr": "Fermeté",
            "it": "Vigore",
            "de": "Robustheit",
            "es": "Robustez",
            "ko": "옹골참"
          },
          "descriptions": {
            "en": "It cannot be knocked out with one hit. One-hit KO moves cannot knock it out, either.",
            "fr": "Le Pokémon encaisse toujours au moins une attaque s’il a tous ses PV. Il est également immunisé contre les capacités pouvant mettre K.O. en un coup.",
            "it": "Evita che il Pokémon vada KO in un sol colpo se ha tutti i PS, e lo rende immune alle mosse che causano KO immediato.",
            "de": "Bietet Schutz gegen K.O.-Attacken. Bei vollen KP übersteht das Pokémon auch K.O.-Treffer.",
            "es": "Evita que el rival pueda debilitarlo de un solo golpe cuando tiene los PS al máximo. También evita los movimientos fulminantes.",
            "ko": "상대 기술을 받아도 일격으로 쓰러지지 않는다. 일격필살 기술도 효과 없다."
          }
        },
        {
          "symbol": "rock_head",
          "textId": 69,
          "names": {
            "en": "Rock Head",
            "fr": "Tête de Roc",
            "it": "Testadura",
            "de": "Steinhaupt",
            "es": "Cabeza Roca",
            "ko": "돌머리"
          },
          "descriptions": {
            "en": "Protects the Pokémon from recoil damage.",
            "fr": "Le Pokémon peut utiliser des capacités occasionnant un contrecoup sans perdre de PV.",
            "it": "Protegge il Pokémon dai contraccolpi.",
            "de": "Verhindert Schaden, der durch Rückstoß entstehen würde.",
            "es": "No puede dañarse con sus propios movimientos.",
            "ko": "반동을 받는 기술을 사용해도 HP가 줄지 않는다."
          }
        },
        {
          "symbol": "overcoat",
          "textId": 142,
          "names": {
            "en": "Overcoat",
            "fr": "Envelocape",
            "it": "Copricapo",
            "de": "Partikelschutz",
            "es": "Funda",
            "ko": "방진"
          },
          "descriptions": {
            "en": "Protects the Pokémon from things like sand, hail, and powder.",
            "fr": "Protège des dégâts occasionnés par les tempêtes de sable ou la grêle, et neutralise les attaques à base de poudre.",
            "it": "Rende immuni ai danni da grandine e tempesta di sabbia, alle mosse Spora, Cottonspora, Sonnifero, Paralizzante e alle mosse “polvere”.",
            "de": "Nimmt weder durch Wetterlagen wie Sandsturm oder Hagel noch durch Pulver oder Puder Schaden.",
            "es": "No le afectan las tormentas de arena, el granizo y los movimientos con polvos.",
            "ko": "모래바람이나 싸라기눈 등의 데미지를 입지 않는다. 가루의 기술을 받지 않는다."
          }
        }
      ],
