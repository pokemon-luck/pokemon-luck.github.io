      "names": {
        "en": "Formidabark",
        "fr": "Formidarbre",
        "it": "Blissey",
        "de": "Heiteira",
        "es": "Blissey",
        "ko": "해피너스"
      },
      "descriptions": {
        "en": "Their eggs are such a delicacy that some say eating one will bring you happiness. These eggs fetch the highest prices on the market.",
        "fr": "",
        "it": "Le sue uova sono talmente deliziose che si dice rendano felice chiunque le mangi. Per questo hanno prezzi altissimi sul mercato.",
        "de": "Sein Ei ist eine Kostbarkeit, denn es heißt, wer davon esse, werde glücklich. Auf dem Markt erzielt es deshalb Spitzenpreise.",
        "es": "Se dice que los huevos de Blissey están tan ricos que dan la felicidad a quien los prueba. Por eso alcanzan precios exorbitantes.",
        "ko": "알을 먹으면 행복해진다고 전해질 정도로 맛이 일품이다. 시장에서 제일 가격이 비싸다."
      },
      "abilities_data": [
        {
          "symbol": "regenerator",
          "textId": 144,
          "names": {
            "en": "Regenerator",
            "fr": "Régé-Force",
            "it": "Rigenergia",
            "de": "Belebekraft",
            "es": "Regeneración",
            "ko": "재생력"
          },
          "descriptions": {
            "en": "Restores a little HP when withdrawn from battle.",
            "fr": "Restaure un peu de PV si le Pokémon est retiré du combat.",
            "it": "Il Pokémon recupera un po’ di PS quando lascia il campo.",
            "de": "Wird das Pokémon ausgewechselt, regeneriert es eine kleine Menge an KP.",
            "es": "Recupera unos pocos PS al ser cambiado por otro Pokémon.",
            "ko": "지닌 포켓몬으로 돌아오면 HP를 조금 회복한다."
          }
        },
        {
          "symbol": "natural_cure",
          "textId": 30,
          "names": {
            "en": "Natural Cure",
            "fr": "Médic Nature",
            "it": "Alternacura",
            "de": "Innere Kraft",
            "es": "Cura Natural",
            "ko": "자연회복"
          },
          "descriptions": {
            "en": "All status conditions heal when the Pokémon switches out.",
            "fr": "Le Pokémon soigne ses altérations de statut en quittant le combat.",
            "it": "Quando il Pokémon viene sostituito, guarisce dai problemi di stato.",
            "de": "Wird das Pokémon ausgewechselt, werden seine Statusprobleme geheilt.",
            "es": "Cura sus problemas de estado al cambiarse con otro Pokémon.",
            "ko": "지닌 포켓몬으로 돌아오면 상태 이상이 회복된다."
          }
        },
        {
          "symbol": "magic_guard",
          "textId": 98,
          "names": {
            "en": "Magic Guard",
            "fr": "Garde Magik",
            "it": "Magicscudo",
            "de": "Magieschild",
            "es": "Muro Mágico",
            "ko": "매직가드"
          },
          "descriptions": {
            "en": "The Pokémon only takes damage from attacks.",
            "fr": "Seules les attaques peuvent blesser le Pokémon.",
            "it": "Il Pokémon subisce danni solo dagli attacchi.",
            "de": "Das Pokémon nimmt nur durch Offensiv-Attacken Schaden.",
            "es": "Solo recibe daño de ataques.",
            "ko": "공격 이외에는 데미지를 입지 않는다."
          }
        }
