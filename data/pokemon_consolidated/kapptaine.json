      "names": {
        "en": "Kapptain",
        "fr": "Kapptaine",
        "it": "Skarmory",
        "de": "Panzaeron",
        "es": "Skarmory",
        "ko": "무장조"
      },
      "descriptions": {
        "en": "Kapptain uses its coral hook to fish, or simply to anchor itself as it rests in the strong currents.",
        "fr": "Kapptaine utilise son crochet fait de corail pour pêcher, ou simplement pour s'ancrer lorsqu'il se repose dans les courants forts.",
        "it": "Le piume che perde vengono usate per fabbricare coltelli affilatissimi, particolarmente apprezzati dai migliori cuochi.",
        "de": "Die Federn, die ihm ausfallen, werden zu Küchenmessern verarbeitet, mit deren Schärfe auch erstklassige Köche zufrieden sind.",
        "es": "Los cuchillos fabricados con las plumas que se le caen son reconocidos entre los cocineros más prestigiosos por la gran calidad de sus filos.",
        "ko": "빠진 날개를 가공해서 만드는 식칼은 일류 요리사도 인정할 정도로 날카롭다."
      },
      "abilities_data": [
        {
          "symbol": "pickpocket",
          "textId": 124,
          "names": {
            "en": "Pickpocket",
            "fr": "Pickpocket",
            "it": "Arraffalesto",
            "de": "Langfinger",
            "es": "Hurto",
            "ko": "나쁜손버릇"
          },
          "descriptions": {
            "en": "Steals an item from an attacker that made direct contact.",
            "fr": "Vole l’objet que tient l’attaquant quand le Pokémon subit une attaque directe.",
            "it": "Se il Pokémon viene colpito da un attacco diretto, ruba lo strumento di chi lo ha attaccato.",
            "de": "Stiehlt das Item des Angreifers bei Berührung.",
            "es": "Si el rival usa un movimiento de contacto al atacar, le roba el objeto.",
            "ko": "접촉한 상대의 도구를 훔친다."
          }
        },
        {
          "symbol": "rain_dish",
          "textId": 44,
          "names": {
            "en": "Rain Dish",
            "fr": "Cuvette",
            "it": "Copripioggia",
            "de": "Regengenuss",
            "es": "Cura Lluvia",
            "ko": "젖은접시"
          },
          "descriptions": {
            "en": "The Pokémon gradually regains HP in rain.",
            "fr": "Le Pokémon récupère progressivement des PV lorsqu’il pleut.",
            "it": "Il Pokémon recupera PS quando piove.",
            "de": "Regeneriert bei Regen nach und nach KP.",
            "es": "Recupera PS de forma gradual cuando llueve.",
            "ko": "비가 오는 날씨일 때 조금씩 HP를 회복한다."
          }
        },
        {
          "symbol": "defiant",
          "textId": 128,
          "names": {
            "en": "Defiant",
            "fr": "Acharné",
            "it": "Agonismo",
            "de": "Siegeswille",
            "es": "Competitivo",
            "ko": "오기"
          },
          "descriptions": {
            "en": "Boosts the Pokémon’s Attack stat sharply when its stats are lowered.",
            "fr": "Augmente beaucoup l’Attaque du Pokémon quand ses stats baissent.",
            "it": "L’Attacco aumenta di molto quando le statistiche diminuiscono a causa di un nemico.",
            "de": "Erhöht den Angriff stark, wenn ein Statuswert gesenkt wurde.",
            "es": "Sube mucho su Ataque cuando el rival le baja las características.",
            "ko": "능력이 떨어지면 공격이 크게 올라간다."
          }
        }
      ],
