      "names": {
        "en": "Oviplume",
        "fr": "Oviplume",
        "it": "Elekid",
        "de": "Elekid",
        "es": "Elekid",
        "ko": "에레키드"
      },
      "descriptions": {
        "en": " ",
        "fr": "",
        "it": "Il rombo dei tuoni lo mette di buon umore, perciò è utile averne una registrazione a portata di mano per quando è triste.",
        "de": "Elekid freut sich, wenn es Donner hört. Es lohnt sich, das Geräusch aufzunehmen und es ihm vorzuspielen, wenn es mal schlecht drauf ist.",
        "es": "El ruido de los truenos le mejora el ánimo. Conviene tener a mano una grabación para cuando esté en horas bajas.",
        "ko": "번개 소리를 들으면 기분이 좋아진다. 우울해질 때를 대비해서 녹음해 두면 편리하다."
      },
      "abilities_data": [
        {
          "symbol": "sturdy",
          "textId": 5,
          "names": {
            "en": "Sturdy",
            "fr": "Fermeté",
            "it": "Vigore",
            "de": "Robustheit",
            "es": "Robustez",
            "ko": "옹골참"
          },
          "descriptions": {
            "en": "It cannot be knocked out with one hit. One-hit KO moves cannot knock it out, either.",
            "fr": "Le Pokémon encaisse toujours au moins une attaque s’il a tous ses PV. Il est également immunisé contre les capacités pouvant mettre K.O. en un coup.",
            "it": "Evita che il Pokémon vada KO in un sol colpo se ha tutti i PS, e lo rende immune alle mosse che causano KO immediato.",
            "de": "Bietet Schutz gegen K.O.-Attacken. Bei vollen KP übersteht das Pokémon auch K.O.-Treffer.",
            "es": "Evita que el rival pueda debilitarlo de un solo golpe cuando tiene los PS al máximo. También evita los movimientos fulminantes.",
            "ko": "상대 기술을 받아도 일격으로 쓰러지지 않는다. 일격필살 기술도 효과 없다."
          }
        },
        {
          "symbol": "levitate",
          "textId": 26,
          "names": {
            "en": "Levitate",
            "fr": "Lévitation",
            "it": "Levitazione",
            "de": "Schwebe",
            "es": "Levitación",
            "ko": "부유"
          },
          "descriptions": {
            "en": "By floating in the air, the Pokémon receives full immunity to all Ground-type moves.",
            "fr": "Le Pokémon flotte, ce qui l’immunise contre les capacités de type Sol.",
            "it": "La capacità di levitare conferisce al Pokémon immunità agli attacchi di tipo Terra.",
            "de": "Verleiht volle Immunität gegen alle Boden-Attacken durch Schwebezustand.",
            "es": "Su capacidad de flotar sobre el suelo le proporciona inmunidad frente a los movimientos de tipo Tierra.",
            "ko": "땅에서 뜨는 것으로 땅타입의 기술을 받지 않는다."
          }
        },
        {
          "symbol": "cursed_body",
          "textId": 130,
          "names": {
            "en": "Cursed Body",
            "fr": "Corps Maudit",
            "it": "Corpofunesto",
            "de": "Tastfluch",
            "es": "Cuerpo Maldito",
            "ko": "저주받은바디"
          },
          "descriptions": {
            "en": "May disable a move used on the Pokémon.",
            "fr": "Quand le Pokémon est touché par une capacité, il inflige parfois Entrave sur celle-ci.",
            "it": "Può bloccare la mossa subita dal Pokémon.",
            "de": "Blockiert eventuell die Attacke, mit welcher der Angreifer es getroffen hat.",
            "es": "Puede anular el movimiento usado en su contra.",
            "ko": "공격을 받으면 상대의 기술을 사슬묶기 상태로 만들 때가 있다."
          }
        }
      ],
