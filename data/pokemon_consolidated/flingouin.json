      "names": {
        "en": "Pingun",
        "fr": "Flingouin",
        "it": "Kingdra",
        "de": "Seedraking",
        "es": "Kingdra",
        "ko": "킹드라"
      },
      "descriptions": {
        "en": "Though its internal temperature is quite high, Pingun prefers cold environments. The steam emanating from its body forms hot springs that are highly popular with other pokémon.",
        "fr": "Malgré sa température corporelle élevée, Flingouin préfère les environnements froids. La vapeur émanant de son corps forme des sources thermales très appréciées des autres pokémon.",
        "it": "Kingdra dorme sui fondali marini dove di solito non esistono forme di vita. Si dice che in caso di tempesta Kingdra si svegli e vada in cerca di prede.",
        "de": "Seedraking schläft auf dem Meeresboden, wo ansonsten niemand lebt. Wenn ein Sturm aufkommt, wacht es auf und macht sich auf die Suche nach Beute.",
        "es": "Kingdra duerme en el lecho marino, donde apenas pueden encontrarse otras formas de vida. Cuando estalla una tormenta, dicen que se despierta y se pone a vagar en busca de su presa.",
        "ko": "생물이 살지 않는 해저에서 자고 있다. 태풍이 오면 눈을 뜨고 먹이를 찾으러 돌아다닌다고 전해진다."
      },
      "abilities_data": [
        {
          "symbol": "no_guard",
          "textId": 99,
          "names": {
            "en": "No Guard",
            "fr": "Annule Garde",
            "it": "Nullodifesa",
            "de": "Schildlos",
            "es": "Indefenso",
            "ko": "노가드"
          },
          "descriptions": {
            "en": "The Pokémon employs no-guard tactics to ensure incoming and outgoing attacks always land.",
            "fr": "Les capacités du Pokémon touchent l’ennemi à coup sûr, mais les capacités de l’ennemi le touchent aussi à coup sûr.",
            "it": "Il Pokémon e chiunque lo attacchi abbassano la guardia e le loro mosse vanno sempre a segno.",
            "de": "Alle Attacken des oder auf das Pokémon gelingen aufgrund seiner deckungslosen Kampftaktik.",
            "es": "Al quedar ambos expuestos, tanto sus movimientos como los del rival acertarán siempre.",
            "ko": "노가드전법에 따라 서로가 사용하는 기술이 반드시 맞게 된다."
          }
        },
        {
          "symbol": "sniper",
          "textId": 97,
          "names": {
            "en": "Sniper",
            "fr": "Sniper",
            "it": "Cecchino",
            "de": "Superschütze",
            "es": "Francotirador",
            "ko": "스나이퍼"
          },
          "descriptions": {
            "en": "Powers up moves if they become critical hits when attacking.",
            "fr": "Lorsque le Pokémon porte un coup critique, les dégâts infligés augmentent encore plus que d’habitude.",
            "it": "Aumenta ulteriormente i danni inflitti dai brutti colpi.",
            "de": "Erhöht bei Volltreffern die Stärke der Attacke noch weiter.",
            "es": "Potencia los golpes críticos que asesta aún más de lo normal.",
            "ko": "공격을 급소에 맞혔을 때 위력이 더욱 올라간다."
          }
        },
        {
          "symbol": "railgun",
          "textId": 306,
          "names": {
            "en": "Railgun",
            "fr": "Railgun",
            "it": "Railgun",
            "de": "Railgun",
            "es": "Railgun",
            "ko": "Railgun"
          },
          "descriptions": {
            "en": "Boosts damage from bullet, gun or cannon moves.",
            "fr": "Augmente les dégâts des attaques de balles, pistolets ou cannons.",
