      "names": {
        "en": "Silvore",
        "fr": "Avargent",
        "it": "Magneton",
        "de": "Magneton",
        "es": "Magneton",
        "ko": "레어코일"
      },
      "descriptions": {
        "en": "The silver of this Pokémon was often coveted and plundered by poachers. Fortunately, Silvore is capable of regenerating its armor.",
        "fr": "L'argent de ce pokémon était souvent convoité et pillé par des braconniers. Fort heureusement, Avargent est capable de régénérer son armure.",
        "it": "Nelle zone abitate dai Magneton, i dispositivi di precisione spesso si guastano a causa delle strane onde prodotte da questi Pokémon.",
        "de": "Es erzeugt seltsame Radiowellen, die Störungen an Präzisionsinstrumenten in seiner Umgebung verursachen.",
        "es": "Las misteriosas ondas eléctricas que emiten provocan toda clase de averías en la electrónica de precisión allí donde viven.",
        "ko": "정체 모를 전파를 발신하기 때문에 레어코일이 사는 곳에는 정밀 기기가 고장 난다."
      },
      "abilities_data": [
        {
          "symbol": "sturdy",
          "textId": 5,
          "names": {
            "en": "Sturdy",
            "fr": "Fermeté",
            "it": "Vigore",
            "de": "Robustheit",
            "es": "Robustez",
            "ko": "옹골참"
          },
          "descriptions": {
            "en": "It cannot be knocked out with one hit. One-hit KO moves cannot knock it out, either.",
            "fr": "Le Pokémon encaisse toujours au moins une attaque s’il a tous ses PV. Il est également immunisé contre les capacités pouvant mettre K.O. en un coup.",
            "it": "Evita che il Pokémon vada KO in un sol colpo se ha tutti i PS, e lo rende immune alle mosse che causano KO immediato.",
            "de": "Bietet Schutz gegen K.O.-Attacken. Bei vollen KP übersteht das Pokémon auch K.O.-Treffer.",
            "es": "Evita que el rival pueda debilitarlo de un solo golpe cuando tiene los PS al máximo. También evita los movimientos fulminantes.",
            "ko": "상대 기술을 받아도 일격으로 쓰러지지 않는다. 일격필살 기술도 효과 없다."
          }
        },
        {
          "symbol": "solid_rock",
          "textId": 116,
          "names": {
            "en": "Solid Rock",
            "fr": "Solide Roc",
            "it": "Solidroccia",
            "de": "Felskern",
            "es": "Roca Sólida",
            "ko": "하드록"
          },
          "descriptions": {
            "en": "Reduces the power of supereffective attacks taken.",
            "fr": "Réduit les dégâts subis lorsque le Pokémon est touché par une capacité super efficace.",
            "it": "Riduce i danni subiti dalle mosse superefficaci.",
            "de": "Reduziert die Stärke von sehr effektiven Attacken und verringert damit den Schaden, den das Pokémon durch sie erleidet.",
            "es": "Mitiga el daño que le infligen los movimientos supereficaces.",
            "ko": "효과가 굉장한 공격의 위력을 약하게 만든다."
          }
        },
        {
          "symbol": "iron_barbs",
          "textId": 160,
          "names": {
            "en": "Iron Barbs",
            "fr": "Épine de Fer",
            "it": "Spineferrate",
            "de": "Eisenstachel",
            "es": "Punta Acero",
            "ko": "철가시"
          },
          "descriptions": {
            "en": "Inflicts damage on the attacker upon contact with iron barbs.",
            "fr": "Inflige des dégâts à l’attaquant lorsque le Pokémon subit une attaque directe.",
            "it": "Se il Pokémon viene colpito da un attacco diretto, infligge danni a sua volta con le sue spine di ferro.",
            "de": "Fügt dem Angreifer bei Berührung mit eisernen Stacheln Schaden zu.",
            "es": "Inflige daño al rival si este le golpea con un movimiento de contacto.",
            "ko": "자신과 접촉한 상대에게 철가시로 데미지를 준다."
          }
        }
      ],
