      "names": {
        "en": "Kramparch",
        "fr": "Crampule",
        "it": "Magmar",
        "de": "Magmar",
        "es": "Magmar",
        "ko": "마그마"
      },
      "descriptions": {
        "en": "Kramparch fills its dorsal pouch with charcoal that it creates. It defends itself by throwing or dumping its burning charcoal on its opponents.",
        "fr": "Crampule remplit sa poche dorsale de charbon de bois qu'il crée. Il se défend en lançant ou en déversant son charbon brûlant sur ses adversaires.",
        "it": "Tutto il suo corpo arde e persino il suo respiro è rovente. Quando starnutisce sputa fiamme dalla bocca.",
        "de": "Mit seinem brennenden Körper und glühenden Atem heizt es seine Umgebung auf. Beim Niesen stößt es Flammen aus.",
        "es": "Su cuerpo arde con tal fuerza que su aliento resulta abrasador. Expulsa llamaradas con tan solo estornudar.",
        "ko": "온몸이 불에 타고 있어서 숨을 쉬기만 해도 뜨겁다. 재채기와 동시에 불꽃을 뿜어낸다."
      },
      "abilities_data": [
        {
          "symbol": "snow_warning",
          "textId": 117,
          "names": {
            "en": "Snow Warning",
            "fr": "Alerte Neige",
            "it": "Scendineve",
            "de": "Hagelalarm",
            "es": "Nevada",
            "ko": "눈퍼뜨리기"
          },
          "descriptions": {
            "en": "The Pokémon summons a hailstorm when it enters a battle.",
            "fr": "Déclenche une tempête de grêle quand le Pokémon entre au combat.",
            "it": "Quando il Pokémon entra in campo, provoca una grandinata.",
            "de": "Löst bei Kampfantritt Hagel aus.",
            "es": "Invoca una tormenta de granizo al entrar en combate.",
            "ko": "등장했을 때 날씨를 싸라기눈으로 만든다."
          }
        },
        {
          "symbol": "ice_body",
          "textId": 115,
          "names": {
            "en": "Ice Body",
            "fr": "Corps Gel",
            "it": "Corpogelo",
            "de": "Eishaut",
            "es": "Gélido",
            "ko": "아이스바디"
          },
          "descriptions": {
            "en": "The Pokémon gradually regains HP in a hailstorm.",
            "fr": "Régénère les PV du Pokémon lors des tempêtes de grêle.",
            "it": "Se grandina, il Pokémon recupera PS.",
            "de": "Regeneriert bei Hagel nach und nach KP.",
            "es": "Recupera PS de forma gradual cuando hay tormentas de granizo.",
            "ko": "날씨가 싸라기눈일 때 HP를 조금씩 회복한다."
          }
        },
        {
          "symbol": "fur_coat",
          "textId": 169,
          "names": {
            "en": "Fur Coat",
            "fr": "Toison Épaisse",
            "it": "Foltopelo",
            "de": "Fellkleid",
            "es": "Pelaje Recio",
            "ko": "퍼코트"
          },
          "descriptions": {
            "en": "Halves the damage from physical moves.",
            "fr": "Divise par deux les dégâts des capacités physiques subies par le Pokémon.",
            "it": "Dimezza il danno subito dalle mosse fisiche.",
            "de": "Halbiert den Schaden, den das Pokémon durch physische Attacken erleidet.",
            "es": "Reduce a la mitad el daño que recibe de ataques físicos del rival.",
            "ko": "상대로부터 받는 물리 기술의 데미지가 절반이 된다."
          }
        }
      ],
