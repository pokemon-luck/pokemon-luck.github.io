      "names": {
        "en": "Meditamarin",
        "fr": "Méditamarin",
        "it": "Hitmontop",
        "de": "Kapoera",
        "es": "Hitmontop",
        "ko": "카포에라"
      },
      "descriptions": {
        "en": " ",
        "fr": "",
        "it": "Hitmontop rotea sulla testa ad alta velocità sferrando calci violenti. Questa tecnica è molto efficace sia in attacco che in difesa. Il Pokémon si muove molto più velocemente roteando che non camminando.",
        "de": "Kapoera dreht sich auf dem Kopf stehend um die eigene Achse und teilt Tritte aus. Seine Technik ist eine bemerkenswerte Mischung aus Angriff und Verteidigung. Es bewegt sich drehend schneller voran als laufend.",
        "es": "Hitmontop hace el pino con la cabeza y se pone a girar rápido al tiempo que reparte patadas. Esta es una técnica ofensiva y defensiva a la vez. Este Pokémon se desplaza más rápido girando sobre sí que caminando.",
        "ko": "고속 회전하며 날리는 킥은 공격과 방어를 겸비한 훌륭한 기술이다. 걷는 것보다 회전하는 편이 빠르다."
      },
      "abilities_data": [
        {
          "symbol": "pickup",
          "textId": 53,
          "names": {
            "en": "Pickup",
            "fr": "Ramassage",
            "it": "Raccolta",
            "de": "Mitnahme",
            "es": "Recogida",
            "ko": "픽업"
          },
          "descriptions": {
            "en": "The Pokémon may pick up the item an opposing Pokémon used during a battle. It may pick up items outside of battle, too.",
            "fr": "Permet parfois au Pokémon de ramasser les objets que ses ennemis ont utilisés. Il lui arrive aussi d’en trouver hors des combats.",
            "it": "Il Pokémon può raccogliere lo strumento usato da un nemico durante la lotta. A volte potrebbe raccogliere strumenti anche fuori dalla lotta.",
            "de": "Hebt gelegentlich von Gegnern benutzte Items auf. Dies geschieht nicht nur während Kämpfen, sondern auch unterwegs.",
            "es": "Puede recoger objetos que el rival haya usado, o bien otros que encuentre en plena aventura.",
            "ko": "상대가 사용한 도구를 주워올 때가 있다. 모험 중에도 주워온다."
          }
        },
        {
          "symbol": "vital_spirit",
          "textId": 72,
          "names": {
            "en": "Vital Spirit",
            "fr": "Esprit Vital",
            "it": "Spiritovivo",
            "de": "Munterkeit",
            "es": "Espíritu Vital",
            "ko": "의기양양"
          },
          "descriptions": {
            "en": "The Pokémon is full of vitality, and that prevents it from falling asleep.",
            "fr": "Empêche le Pokémon de s’endormir.",
            "it": "Il Pokémon è talmente vivace che non può addormentarsi.",
            "de": "Das Pokémon ist so munter, dass es nicht einschlafen kann.",
            "es": "Su determinación le impide quedarse dormido.",
            "ko": "의기양양해져서 잠듦 상태가 되지 않는다."
          }
        },
        {
          "symbol": "pure_power",
          "textId": 74,
          "names": {
            "en": "Pure Power",
            "fr": "Force Pure",
            "it": "Forzapura",
            "de": "Mentalkraft",
            "es": "Energía Pura",
            "ko": "순수한힘"
          },
          "descriptions": {
            "en": "Using its pure power, the Pokémon doubles its Attack stat.",
            "fr": "Le Pokémon utilise sa maîtrise du yoga pour doubler la puissance de ses capacités physiques.",
            "it": "L’Attacco del Pokémon raddoppia grazie alla sua padronanza delle tecniche yoga.",
            "de": "Verdoppelt mit reiner Willenskraft die Stärke seiner physischen Attacken.",
            "es": "Duplica la potencia de sus ataques físicos gracias al yoga.",
            "ko": "요가의 힘으로 물리공격의 위력이 2배가 된다."
          }
        }
      ],
