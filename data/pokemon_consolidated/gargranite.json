      "names": {
        "en": "Gargranite",
        "fr": "Gargranite",
        "it": "Golem",
        "de": "Geowaz",
        "es": "Golem",
        "ko": "딱구리"
      },
      "descriptions": {
        "en": "Its very large mass, due to its extremely compact stone body, makes Gargranite much heavier than it appears.",
        "fr": "Sa masse très importante, due à son corps de pierre extrêmement compacte, rend Gargranite beaucoup plus lourd qu'il n'en a l'air.",
        "it": "Quando invecchia, non fa più la muta. Il guscio dei Golem molto anziani si ricopre di muschio tingendosi di verde.",
        "de": "Im Alter hört es auf, sich zu häuten. Der Panzer betagter Geowaz ist mit dichtem, grünem Moos bewachsen.",
        "es": "A medida que envejece, pierde la facultad de mudar la piel. Se han observado ejemplares de edad avanzada totalmente cubiertos de musgo.",
        "ko": "나이가 들면 탈피를 하지 않는다. 긴 세월을 산 딱구리의 껍질은 이끼가 끼어 초록색이다."
      },
      "abilities_data": [
        {
          "symbol": "sturdy",
          "textId": 5,
          "names": {
            "en": "Sturdy",
            "fr": "Fermeté",
            "it": "Vigore",
            "de": "Robustheit",
            "es": "Robustez",
            "ko": "옹골참"
          },
          "descriptions": {
            "en": "It cannot be knocked out with one hit. One-hit KO moves cannot knock it out, either.",
            "fr": "Le Pokémon encaisse toujours au moins une attaque s’il a tous ses PV. Il est également immunisé contre les capacités pouvant mettre K.O. en un coup.",
            "it": "Evita che il Pokémon vada KO in un sol colpo se ha tutti i PS, e lo rende immune alle mosse che causano KO immediato.",
            "de": "Bietet Schutz gegen K.O.-Attacken. Bei vollen KP übersteht das Pokémon auch K.O.-Treffer.",
            "es": "Evita que el rival pueda debilitarlo de un solo golpe cuando tiene los PS al máximo. También evita los movimientos fulminantes.",
            "ko": "상대 기술을 받아도 일격으로 쓰러지지 않는다. 일격필살 기술도 효과 없다."
          }
        },
        {
          "symbol": "rough_skin",
          "textId": 24,
          "names": {
            "en": "Rough Skin",
            "fr": "Peau Dure",
            "it": "Cartavetro",
            "de": "Rauhaut",
            "es": "Piel Tosca",
            "ko": "까칠한피부"
          },
          "descriptions": {
            "en": "This Pokémon inflicts damage with its rough skin to the attacker on contact.",
            "fr": "Blesse l’attaquant lorsque le Pokémon subit une attaque directe.",
            "it": "Se il Pokémon è colpito da un attacco diretto, grazie alla sua pelle ruvida infligge danni a sua volta.",
            "de": "Angreifer werden durch die raue Haut des Pokémon bei direkten Attacken verletzt.",
            "es": "Hiere con su piel áspera al rival que lo ataque con un movimiento de contacto.",
            "ko": "공격을 받았을 때 자신에게 접촉한 상대를 까칠까칠한 피부로 상처를 입힌다."
          }
        },
        {
          "symbol": "solid_rock",
          "textId": 116,
          "names": {
            "en": "Solid Rock",
            "fr": "Solide Roc",
            "it": "Solidroccia",
            "de": "Felskern",
            "es": "Roca Sólida",
            "ko": "하드록"
          },
          "descriptions": {
            "en": "Reduces the power of supereffective attacks taken.",
            "fr": "Réduit les dégâts subis lorsque le Pokémon est touché par une capacité super efficace.",
            "it": "Riduce i danni subiti dalle mosse superefficaci.",
            "de": "Reduziert die Stärke von sehr effektiven Attacken und verringert damit den Schaden, den das Pokémon durch sie erleidet.",
            "es": "Mitiga el daño que le infligen los movimientos supereficaces.",
            "ko": "효과가 굉장한 공격의 위력을 약하게 만든다."
          }
        }
      ],
