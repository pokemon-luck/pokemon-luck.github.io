      "names": {
        "en": "Gasteroid",
        "fr": "Gastéroïde",
        "it": "Miltank",
        "de": "Miltank",
        "es": "Miltank",
        "ko": "밀탱크"
      },
      "descriptions": {
        "en": "It produces over five gallons of milk a day. The higher the quality of the pastures it lives in, the richer and tastier its milk becomes.",
        "fr": "",
        "it": "Produce 20 litri di latte al giorno. Più alta è la qualità del pascolo, più gustoso sarà il latte.",
        "de": "Es gibt täglich 20 l Milch. Je besser die Qualität des Grases ist, desto schmackhafter ist sie.",
        "es": "Produce 20 litros de leche al día, que es más sabrosa cuanto mejor sea el pasto.",
        "ko": "하루에 20리터의 젖을 짠다. 목초의 질이 좋은 산지일수록 밀크는 진해서 맛있다."
      },
      "abilities_data": [
        {
          "symbol": "sturdy",
          "textId": 5,
          "names": {
            "en": "Sturdy",
            "fr": "Fermeté",
            "it": "Vigore",
            "de": "Robustheit",
            "es": "Robustez",
            "ko": "옹골참"
          },
          "descriptions": {
            "en": "It cannot be knocked out with one hit. One-hit KO moves cannot knock it out, either.",
            "fr": "Le Pokémon encaisse toujours au moins une attaque s’il a tous ses PV. Il est également immunisé contre les capacités pouvant mettre K.O. en un coup.",
            "it": "Evita che il Pokémon vada KO in un sol colpo se ha tutti i PS, e lo rende immune alle mosse che causano KO immediato.",
            "de": "Bietet Schutz gegen K.O.-Attacken. Bei vollen KP übersteht das Pokémon auch K.O.-Treffer.",
            "es": "Evita que el rival pueda debilitarlo de un solo golpe cuando tiene los PS al máximo. También evita los movimientos fulminantes.",
            "ko": "상대 기술을 받아도 일격으로 쓰러지지 않는다. 일격필살 기술도 효과 없다."
          }
        },
        {
          "symbol": "shell_armor",
          "textId": 75,
          "names": {
            "en": "Shell Armor",
            "fr": "Coque Armure",
            "it": "Guscioscudo",
            "de": "Panzerhaut",
            "es": "Caparazón",
            "ko": "조가비갑옷"
          },
          "descriptions": {
            "en": "A hard shell protects the Pokémon from critical hits.",
            "fr": "Le Pokémon est protégé des coups critiques par sa carapace.",
            "it": "Il Pokémon è protetto da un guscio robusto che gli evita di subire brutti colpi.",
            "de": "Wehrt gegnerische Volltreffer mit einem harten Panzer ab.",
            "es": "La robusta coraza que lo protege bloquea los golpes críticos.",
            "ko": "단단한 껍질의 보호를 받아 상대의 공격이 급소에 맞지 않는다."
          }
        },
        {
          "symbol": "solid_rock",
          "textId": 116,
          "names": {
            "en": "Solid Rock",
            "fr": "Solide Roc",
            "it": "Solidroccia",
            "de": "Felskern",
            "es": "Roca Sólida",
            "ko": "하드록"
          },
          "descriptions": {
            "en": "Reduces the power of supereffective attacks taken.",
            "fr": "Réduit les dégâts subis lorsque le Pokémon est touché par une capacité super efficace.",
            "it": "Riduce i danni subiti dalle mosse superefficaci.",
            "de": "Reduziert die Stärke von sehr effektiven Attacken und verringert damit den Schaden, den das Pokémon durch sie erleidet.",
            "es": "Mitiga el daño que le infligen los movimientos supereficaces.",
            "ko": "효과가 굉장한 공격의 위력을 약하게 만든다."
          }
        }
      ],
