      "names": {
        "en": "Wintrygo",
        "fr": "Wendhiver",
        "it": "Slowbro",
        "de": "Lahmus",
        "es": "Slowbro",
        "ko": "야도란"
      },
      "descriptions": {
        "en": "It is said that its howl resonates through the mountains, like a call to fierce storms.",
        "fr": "On raconte que son hurlement résonne à travers les montagnes, comme un appel aux tempêtes furieuses",
        "it": "Ha sempre un’aria un po’ assente. Se perde la coda e lo Shellder che vi è attaccato, si trasforma in uno Slowpoke.",
        "de": "Ein von Grund auf begriffsstutziges Pokémon. Verliert es seine Rute mitsamt Muschas, entwickelt es sich zu Flegmon zurück.",
        "es": "Vive en un estado de distracción constante. Si el Shellder que tiene en la cola se desprende, revierte a su estadio evolutivo anterior.",
        "ko": "기본적으로 멍하니 있다. 꼬리가 끊겨 셀러가 떨어지면 야돈으로 돌아간다."
      },
      "abilities_data": [
        {
          "symbol": "snow_warning",
          "textId": 117,
          "names": {
            "en": "Snow Warning",
            "fr": "Alerte Neige",
            "it": "Scendineve",
            "de": "Hagelalarm",
            "es": "Nevada",
            "ko": "눈퍼뜨리기"
          },
          "descriptions": {
            "en": "The Pokémon summons a hailstorm when it enters a battle.",
            "fr": "Déclenche une tempête de grêle quand le Pokémon entre au combat.",
            "it": "Quando il Pokémon entra in campo, provoca una grandinata.",
            "de": "Löst bei Kampfantritt Hagel aus.",
            "es": "Invoca una tormenta de granizo al entrar en combate.",
            "ko": "등장했을 때 날씨를 싸라기눈으로 만든다."
          }
        },
        {
          "symbol": "refrigerate",
          "textId": 174,
          "names": {
            "en": "Refrigerate",
            "fr": "Peau Gelée",
            "it": "Pellegelo",
            "de": "Frostschicht",
            "es": "Piel Helada",
            "ko": "프리즈스킨"
          },
          "descriptions": {
            "en": "Normal-type moves become Ice-type moves. The power of those moves is boosted a little.",
            "fr": "Les capacités de type Normal deviennent de type Glace. Leur puissance augmente légèrement.",
            "it": "Le mosse di tipo Normale diventano di tipo Ghiaccio e la loro potenza aumenta un po’.",
            "de": "Attacken vom Typ Normal nehmen den Typ Eis an und ihre Stärke erhöht sich ein wenig.",
            "es": "Convierte los movimientos de tipo Normal en tipo Hielo y aumenta ligeramente su potencia.",
            "ko": "노말타입의 기술이 얼음타입이 된다. 위력이 조금 올라간다."
          }
        },
        {
          "symbol": "fur_coat",
          "textId": 169,
          "names": {
            "en": "Fur Coat",
            "fr": "Toison Épaisse",
            "it": "Foltopelo",
            "de": "Fellkleid",
            "es": "Pelaje Recio",
            "ko": "퍼코트"
          },
          "descriptions": {
            "en": "Halves the damage from physical moves.",
            "fr": "Divise par deux les dégâts des capacités physiques subies par le Pokémon.",
            "it": "Dimezza il danno subito dalle mosse fisiche.",
            "de": "Halbiert den Schaden, den das Pokémon durch physische Attacken erleidet.",
            "es": "Reduce a la mitad el daño que recibe de ataques físicos del rival.",
            "ko": "상대로부터 받는 물리 기술의 데미지가 절반이 된다."
          }
        }
      ],
