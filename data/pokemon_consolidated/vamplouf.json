      "names": {
        "en": "Tubat",
        "fr": "Splashouris",
        "it": "Remoraid",
        "de": "Remoraid",
        "es": "Remoraid",
        "ko": "총어"
      },
      "descriptions": {
        "en": "Even if able to take flight, Tubat spends most of its time floating along the currents thanks to its static electricity inflated fur.",
        "fr": "Bien que capable de prendre son envol, Splashouris passe son temps à flotter le long des courants grâce à son pelage gonflé d'électricité statique.",
        "it": "Si attacca a Mantine e si ciba dei suoi avanzi. Quando Mantine viene attaccato, lotta insieme a lui.",
        "de": "Es heftet sich an Mantax und ernährt sich von dessen Essensresten. Wird Mantax angegriffen, kämpft es gemeinsam mit ihm.",
        "es": "Se adhiere a los Mantine para alimentarse de las sobras de su comida. Si atacan a su anfitrión, luchará junto a él.",
        "ko": "만타인에 달라붙어 남긴 음식을 먹고 산다. 만타인이 습격당하면 함께 싸운다."
      },
      "abilities_data": [
        {
          "symbol": "levitate",
          "textId": 26,
          "names": {
            "en": "Levitate",
            "fr": "Lévitation",
            "it": "Levitazione",
            "de": "Schwebe",
            "es": "Levitación",
            "ko": "부유"
          },
          "descriptions": {
            "en": "By floating in the air, the Pokémon receives full immunity to all Ground-type moves.",
            "fr": "Le Pokémon flotte, ce qui l’immunise contre les capacités de type Sol.",
            "it": "La capacità di levitare conferisce al Pokémon immunità agli attacchi di tipo Terra.",
            "de": "Verleiht volle Immunität gegen alle Boden-Attacken durch Schwebezustand.",
            "es": "Su capacidad de flotar sobre el suelo le proporciona inmunidad frente a los movimientos de tipo Tierra.",
            "ko": "땅에서 뜨는 것으로 땅타입의 기술을 받지 않는다."
          }
        },
        {
          "symbol": "drizzle",
          "textId": 2,
          "names": {
            "en": "Drizzle",
            "fr": "Crachin",
            "it": "Piovischio",
            "de": "Niesel",
            "es": "Llovizna",
            "ko": "잔비"
          },
          "descriptions": {
            "en": "The Pokémon makes it rain when it enters a battle.",
            "fr": "Le Pokémon invoque la pluie quand il entre au combat.",
            "it": "Quando il Pokémon entra in campo, attira la pioggia.",
            "de": "Ruft bei Kampfantritt Regen herbei.",
            "es": "Hace que llueva al entrar en combate.",
            "ko": "등장했을 때 날씨를 비로 만든다."
          }
        },
        {
          "symbol": "volt_absorb",
          "textId": 10,
          "names": {
            "en": "Volt Absorb",
            "fr": "Absorbe-Volt",
            "it": "Assorbivolt",
            "de": "Voltabsorber",
            "es": "Absorbe Elec",
            "ko": "축전"
          },
          "descriptions": {
            "en": "Restores HP if hit by an Electric-type move instead of taking damage.",
            "fr": "Si le Pokémon est touché par une capacité Électrik, il ne subit aucun dégât et regagne des PV à la place.",
            "it": "Se il Pokémon viene colpito da una mossa di tipo Elettro, recupera PS anziché subire danni.",
            "de": "Treffer durch Elektro-Attacken verursachen keinen Schaden, sondern regenerieren stattdessen KP.",
            "es": "Si le alcanza un movimiento de tipo Eléctrico, recupera PS en vez de sufrir daño.",
            "ko": "전기타입의 기술을 받으면 데미지를 받지 않고 회복한다."
          }
        }
      ],
